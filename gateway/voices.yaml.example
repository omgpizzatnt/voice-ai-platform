voices:
  # Default TTS voice - 使用预训练底模
  default:
    name: "Default Voice"
    type: tts
    version: "v2"
    gpt_weights: ""
    sovits_weights: ""
    refer_wav_path: "/workspace/models/custom_voices/gptsovits/default/reference.wav"
    prompt_text: "参考音频对应的文本内容"
    prompt_lang: "zh"
    language: "auto"
    top_k: 20
    top_p: 0.6
    temperature: 0.6
    speed: 1.0
    text_split_method: "cut5"
    batch_size: 1
    sample_steps: 32

  # Custom TTS voice - 使用自定义训练模型
  xiaoming:
    name: "小明"
    type: tts
    version: "v2"
    gpt_weights: "/workspace/models/custom_voices/gptsovits/xiaoming/xiaoming_gpt.ckpt"
    sovits_weights: "/workspace/models/custom_voices/gptsovits/xiaoming/xiaoming_sovits.pth"
    refer_wav_path: "/workspace/models/custom_voices/gptsovits/xiaoming/reference.wav"
    prompt_text: "这是一段参考音频的文本内容"
    prompt_lang: "zh"
    language: "zh"
    top_k: 20
    top_p: 0.6
    temperature: 0.6
    speed: 1.0
    text_split_method: "cut5"
    batch_size: 1
    sample_steps: 32

  # RVC Pipeline - TTS + 变声
  anime_girl:
    name: "动漫女声"
    type: rvc_pipeline
    base_tts_voice: "default"
    rvc_model_name: "anime_girl"
    pitch: 6
    f0_method: "rmvpe"
    index_rate: 0.75
    filter_radius: 3
    resample_sr: 0
    rms_mix_rate: 0.25
    protect: 0.33
